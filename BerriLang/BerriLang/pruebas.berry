    yoru x = 5
    yoru y = 10;
}
kaizoku

// ====================================================
// PRUEBA 9 - ERROR SINTÁCTICO: Paréntesis sin cerrar
// ====================================================
nakama PruebaError4 {
    luffy (x > 0 {
        nami(x);
    }
}
kaizoku

