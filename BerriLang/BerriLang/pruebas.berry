// ====================================================
// PRUEBA 1 - Válida: Variables y operaciones básicas
// ====================================================
nakama Prueba1 {
    yoru a = 10;
    yoru b = 20;
    yoru suma = a + b;
    nami(suma);
}
kaizoku

// ====================================================
// PRUEBA 2 - Válida: Condicional luffy/sino
// ====================================================
nakama Prueba2 {
    yoru edad = 21;
    luffy (edad >= 18) {
        nami("Eres mayor de edad, nakama!");
    } sino {
        nami("Eres menor, sigue entrenando!");
    }
}
kaizoku

// ====================================================
// PRUEBA 3 - Válida: Ciclo chopper (while)
// ====================================================
nakama Prueba3 {
    yoru i = 0;
    chopper (i < 10) {
        nami(i);
        i = i + 1;
    }
}
kaizoku

// ====================================================
// PRUEBA 4 - Válida: Función con usopp
// ====================================================
nakama Prueba4 {
    usopp potencia(yoru base, yoru exp) {
        yoru resultado = base * exp;
        sanji resultado;
    }
    nami("Funcion definida!");
}
kaizoku

// ====================================================
// PRUEBA 5 - Válida: Múltiples tipos y booleano
// ====================================================
nakama Prueba5 {
    gomu nombre = "Roronoa Zoro";
    zoro altura = 1.81;
    haki esPirata = mera;
    nami(nombre);
    nami(altura);
    nami(esPirata);
}
kaizoku

